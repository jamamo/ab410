rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if owns(userId);
      allow delete: if false;

      match /progress/{documentId} {
        allow read, write: if owns(userId);
      }
    }

    match /learnerProgress/{userId} {
      allow read: if signedIn();
      allow create, update: if owns(userId)
        && request.resource.data.displayName in ['Jama', 'Ismail'];
      allow delete: if false;
    }
  }
}