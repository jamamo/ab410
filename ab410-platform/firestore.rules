rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if owns(userId);
      allow delete: if false;

      match /progress/{documentId} {
        allow read, write: if owns(userId);
      }
    }

    match /learnerProgress/{profileId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && profileId in ['jama', 'ismail']
        && request.resource.data.ownerUid == request.auth.uid
        && (
          (profileId == 'jama' && request.resource.data.displayName == 'Jama')
          || (profileId == 'ismail' && request.resource.data.displayName == 'Ismail')
        );
      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.displayName == resource.data.displayName;
      allow delete: if false;
    }
  }
}
