<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>AB-410 Academy</title>
  <meta name="description" content="Exam-first AB-410 learning platform for building intelligent applications with Microsoft Power Platform.">
  <link rel="stylesheet" href="css/styles.css">
  <link rel="stylesheet" href="css/auth.css">
  <link rel="stylesheet" href="css/progress-dashboard.css">
</head>
<body class="auth-pending">
  <a class="skip-link" href="#app-view">Skip to content</a>

  <header class="shell-header">
    <div class="brand-block">
      <div class="brand-mark" aria-hidden="true">AB</div>
      <div>
        <p class="eyebrow">Microsoft AB-410</p>
        <h1>Intelligent Applications Builder Academy</h1>
      </div>
    </div>
    <div class="header-actions">
      <div class="lens-switch" aria-label="Learning lens">
        <button class="lens-button active" type="button" data-lens="healthcare">Healthcare</button>
        <button class="lens-button" type="button" data-lens="engineering">Engineering</button>
      </div>
      <button class="ghost-button" id="reset-progress" type="button">Reset Progress</button>
    </div>
  </header>

  <nav class="primary-tabs" aria-label="Primary">
    <button class="tab-button active" type="button" data-view="dashboard">Dashboard</button>
    <button class="tab-button" type="button" data-view="course">Course</button>
    <button class="tab-button" type="button" data-view="labs">Labs</button>
    <button class="tab-button" type="button" data-view="practice">Practice</button>
    <button class="tab-button" type="button" data-view="playbook">Playbook</button>
  </nav>

  <main id="app-view" class="app-view" tabindex="-1"></main>

  <template id="empty-state-template">
    <section class="empty-state">
      <p>No matching content.</p>
    </section>
  </template>

  <script src="js/courseData.js"></script>
  <script type="module" src="js/app.js"></script>
</body>
</html>
